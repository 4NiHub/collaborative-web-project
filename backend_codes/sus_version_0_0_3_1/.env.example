# Application
APP_NAME="SuS Portal"
APP_ENV=local                   # change to production on server
APP_KEY=                        # run: php artisan key:generate
APP_DEBUG=true                  # set to false in production!!!
APP_URL=http://localhost        # change to https://your-domain.com in production
# In production: APP_URL=https://smart-university.site

# Locale
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Database - PostgreSQL (used in this project)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=your_database_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# Alternative for quick local testing (SQLite)
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# Session & Cache
SESSION_DRIVER=file             # file | database | redis (redis best in production)
SESSION_LIFETIME=120
SESSION_ENCRYPT=true            # recommended
CACHE_STORE=file                # file | database | redis (redis best in production)

# Queue (for emails, jobs)
QUEUE_CONNECTION=sync           # sync | database | redis (use redis in production)

# Redis (optional but recommended for production caching/queue/2FA rate limiting)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail - 2FA & notifications
# Local development (Mailpit: http://localhost:8025)
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="SuS Portal"

# Production - Resend (strongly recommended for real 2FA emails)
# MAIL_MAILER=resend
# RESEND_API_KEY=
# MAIL_FROM_ADDRESS=noreply@your-domain.site
# MAIL_FROM_NAME="SuS Portal – IDU"

# Security
BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug                 # use info or warning in production

# Vite / Frontend
VITE_APP_NAME="${APP_NAME}"